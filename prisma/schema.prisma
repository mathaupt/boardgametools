// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SQL_DATABASE_URL")
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          String    @default("USER")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  ownedGames      Game[]
  createdSessions GameSession[]
  sessionPlayers  SessionPlayer[]
  ownedGroups     Group[]
  groupMembers    GroupMember[]
  createdEvents   Event[]
  eventInvites    EventInvite[]
  gameProposals   GameProposal[]
  votes           Vote[]
  dateVotes       DateVote[]
  passwordResetTokens PasswordResetToken[]
  gameSeries      GameSeries[]
  createdPolls    GroupPoll[]      @relation("CreatedPolls")
  groupPollVotes  GroupPollVote[]  @relation("GroupPollVotes")
  groupComments   GroupComment[]   @relation("GroupComments")
  apiLogs         ApiLog[]         @relation("apiLogs")
}

// ============================================
// GAMES
// ============================================

model Game {
  id              String    @id @default(cuid())
  name            String
  description     String?
  minPlayers      Int       @default(1)
  maxPlayers      Int       @default(4)
  playTimeMinutes Int?
  complexity      Int?      // 1-5 scale
  bggId           String?   // BoardGameGeek ID
  ean             String?   // EAN/UPC barcode
  imageUrl        String?
  ownerId         String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sessions        GameSession[]
  proposals       GameProposal[]
  selectedEvents  Event[]         @relation("SelectedGame")
  seriesEntries   GameSeriesEntry[]
}

// ============================================
// GAME SESSIONS
// ============================================

model GameSession {
  id              String    @id @default(cuid())
  gameId          String
  playedAt        DateTime  @default(now())
  durationMinutes Int?
  notes           String?
  createdById     String
  createdAt       DateTime  @default(now())

  // Relations
  game            Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdBy       User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  players         SessionPlayer[]
}

model SessionPlayer {
  id          String    @id @default(cuid())
  sessionId   String
  userId      String
  score       Int?
  isWinner    Boolean   @default(false)
  placement   Int?

  // Relations
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

// ============================================
// GROUPS
// ============================================

model Group {
  id          String    @id @default(cuid())
  name        String
  description String?
  ownerId     String
  isPublic    Boolean   @default(false)
  shareToken  String?   @unique
  password    String?   // Optional simple page password for link-based access
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  events      Event[]
  polls       GroupPoll[]
  comments    GroupComment[]
}

model GroupMember {
  id        String    @id @default(cuid())
  groupId   String
  userId    String
  role      String    @default("member") // owner, admin, member
  joinedAt  DateTime  @default(now())

  // Relations
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

// ============================================
// GROUP POLLS & COMMENTS
// ============================================

model GroupPoll {
  id          String    @id @default(cuid())
  groupId     String
  title       String
  description String?
  type        String    @default("single") // single, multiple
  status      String    @default("open")   // open, closed
  createdById String
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  // Relations
  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User              @relation("CreatedPolls", fields: [createdById], references: [id], onDelete: Cascade)
  options     GroupPollOption[]
  comments    GroupComment[]
}

model GroupPollOption {
  id        String    @id @default(cuid())
  pollId    String
  text      String
  sortOrder Int       @default(0)

  // Relations
  poll      GroupPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     GroupPollVote[]
}

model GroupPollVote {
  id         String    @id @default(cuid())
  optionId   String
  voterName  String    // Display name (for anonymous/public voting)
  userId     String?   // Optional - linked user if logged in
  createdAt  DateTime  @default(now())

  // Relations
  option     GroupPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user       User?          @relation("GroupPollVotes", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([optionId, voterName])
}

model GroupComment {
  id         String    @id @default(cuid())
  groupId    String
  pollId     String?   // Optional - on a poll or on the group itself
  authorName String    // Display name
  userId     String?   // Optional - linked user if logged in
  content    String
  createdAt  DateTime  @default(now())

  // Relations
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  poll       GroupPoll? @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user       User?      @relation("GroupComments", fields: [userId], references: [id], onDelete: SetNull)
}

// ============================================
// EVENTS & VOTING
// ============================================

model Event {
  id              String    @id @default(cuid())
  title           String
  description     String?
  eventDate       DateTime
  location        String?
  status          String    @default("draft") // draft, voting, closed
  createdById     String
  groupId         String?
  selectedGameId  String?
  isPublic        Boolean   @default(false)
  shareToken      String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  createdBy       User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  group           Group?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  selectedGame    Game?           @relation("SelectedGame", fields: [selectedGameId], references: [id], onDelete: SetNull)
  selectedDate    DateTime?
  invites         EventInvite[]
  proposals       GameProposal[]
  guestParticipants GuestParticipant[]
  dateProposals   DateProposal[]
}

model EventInvite {
  id          String    @id @default(cuid())
  eventId     String
  userId      String?
  email       String?
  status      String    @default("pending") // pending, accepted, declined
  invitedAt   DateTime  @default(now())
  respondedAt DateTime?

  // Relations
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@unique([eventId, email])
}

model GameProposal {
  id          String    @id @default(cuid())
  eventId     String
  gameId      String
  proposedById String
  createdAt   DateTime  @default(now())

  // Relations
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  game        Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  proposedBy  User      @relation(fields: [proposedById], references: [id], onDelete: Cascade)
  votes       Vote[]
  guestVotes  GuestVote[]

  @@unique([eventId, gameId])
}

model Vote {
  id          String    @id @default(cuid())
  proposalId  String
  userId      String
  createdAt   DateTime  @default(now())

  // Relations
  proposal    GameProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
}

model GuestParticipant {
  id        String   @id @default(cuid())
  eventId   String
  nickname  String
  createdAt DateTime @default(now())

  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes     GuestVote[]
  dateVotes GuestDateVote[]

  @@unique([eventId, nickname])
}

model GuestVote {
  id          String   @id @default(cuid())
  guestId     String
  proposalId  String
  createdAt   DateTime @default(now())

  guest       GuestParticipant @relation(fields: [guestId], references: [id], onDelete: Cascade)
  proposal    GameProposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([guestId, proposalId])
}

// ============================================
// DATE POLLING
// ============================================

model DateProposal {
  id          String    @id @default(cuid())
  eventId     String
  date        DateTime  // the proposed date (date only, time 00:00)
  createdAt   DateTime  @default(now())

  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes       DateVote[]
  guestVotes  GuestDateVote[]

  @@unique([eventId, date])
}

model DateVote {
  id            String    @id @default(cuid())
  dateProposalId String
  userId        String
  availability  String    @default("yes") // yes, maybe, no
  createdAt     DateTime  @default(now())

  dateProposal  DateProposal @relation(fields: [dateProposalId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dateProposalId, userId])
}

model GuestDateVote {
  id            String    @id @default(cuid())
  dateProposalId String
  guestId       String
  availability  String    @default("yes") // yes, maybe, no
  createdAt     DateTime  @default(now())

  dateProposal  DateProposal     @relation(fields: [dateProposalId], references: [id], onDelete: Cascade)
  guest         GuestParticipant @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([dateProposalId, guestId])
}

// ============================================
// GAME SERIES (Spielereihen)
// ============================================

model GameSeries {
  id          String    @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  entries     GameSeriesEntry[]
}

model GameSeriesEntry {
  id          String    @id @default(cuid())
  seriesId    String
  gameId      String
  sortOrder   Int       @default(0)
  played      Boolean   @default(false)
  playedAt    DateTime?
  rating      Int?      // 1-5 stars
  difficulty  String?   // "einsteiger", "fortgeschritten", "profi"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  series      GameSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  game        Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([seriesId, gameId])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── API Monitoring ──────────────────────────────────────────────

model ApiLog {
  id           String   @id @default(cuid())
  method       String   // GET, POST, PUT, DELETE, PATCH
  path         String   // /api/games, /api/events/abc123 etc.
  statusCode   Int
  durationMs   Int      // Response time in ms
  userId       String?  // null for unauthenticated requests
  userAgent    String?
  ip           String?
  errorMessage String?  // only set on 4xx/5xx
  createdAt    DateTime @default(now())

  user User? @relation("apiLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([path])
  @@index([userId])
  @@index([statusCode])
}
