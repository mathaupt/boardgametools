# .env.local.example — Kopieren als .env.local fuer lokale Entwicklung
# cp .env.local.example .env.local

# Database (PostgreSQL via Prisma) — Lokale Docker- oder native Instanz
SQL_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boardgametools_dev"

# NextAuth — Lokale Entwicklung
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="local-dev-secret-nur-fuer-entwicklung"

# BGG API (optional — leer lassen wenn nicht benoetigt)
BGG_API_URL="https://boardgamegeek.com/xmlapi2"
BGG_AUTH_TOKEN=""

# Password reset / mailer — Lokaler MailHog oder Mailpit
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
PASSWORD_RESET_SENDER="BoardGameTools <no-reply@localhost>"
PASSWORD_RESET_TOKEN_TTL_MINUTES="60"
