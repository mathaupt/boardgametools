{
  "name": "boardgametools",
  "version": "0.40.1",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "dev:webpack": "NODE_OPTIONS='--max-old-space-size=4096' next dev --webpack",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:deploy": "node scripts/prisma-deploy.js",
    "build": "npm run prisma:deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:related": "vitest run --reporter=default",
    "test:e2e": "codeceptjs run --steps --config tests/e2e/codecept.conf.ts",
    "test:e2e:headless": "HEADLESS=true codeceptjs run --steps --config tests/e2e/codecept.conf.ts",
    "analyze": "ANALYZE=true next build",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "security-check": "bash scripts/security-check.sh",
    "security-check:only": "bash scripts/security-check.sh --only",
    "security-check:strict": "bash scripts/security-check.sh --strict",
    "security-check:json": "bash scripts/security-check.sh --json",
    "security-check:fast": "bash scripts/security-check.sh --no-audit",
    "security-check:list": "bash scripts/security-check.sh --list",
    "review-evaluate": "node scripts/review-evaluate.mjs --apply",
    "review-evaluate:json": "node scripts/review-evaluate.mjs --json",
    "review-evaluate:strict": "node scripts/review-evaluate.mjs --apply --strict",
    "review-evaluate:report": "node scripts/review-evaluate.mjs",
    "review-evaluate:regression": "node scripts/review-evaluate.mjs --apply --fail-on-regression",
    "backup:prod": "bash scripts/backup-prod-db.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.563.0",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@codeceptjs/configure": "^1.0.6",
    "@next/bundle-analyzer": "^16.2.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.1",
    "codeceptjs": "^3.5.4",
    "eslint": "^9.18.0",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "prisma": "^7.5.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "vitest related --run"
    ]
  }
}
